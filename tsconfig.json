{
    "compilerOptions": {
        "target": "es2021",
        "moduleResolution": "Bundler",
        "module": "esnext",
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "noEmitOnError": true,
        "allowSyntheticDefaultImports": true, // for BN.js (forwarding tests)
        "types": [], // avoid pulling in node types
        "lib": ["dom", "esnext"],
        "skipLibCheck": true, // Avoid Node types brought in in tests by e.g. BN.js from colliding with DOM types 
    },
}
